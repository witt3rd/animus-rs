# Animus instance configuration
#
# Each instance is an OS user account. Paths follow XDG.
# This file lives at $XDG_CONFIG_HOME/animus/.env or in the repo root for dev.

# XDG overrides (usually not needed — defaults are standard)
# XDG_CONFIG_HOME=~/.config
# XDG_DATA_HOME=~/.local/share
# XDG_CACHE_HOME=~/.cache

# Application
DATABASE_URL=postgres://animus:animus_dev@localhost:5432/animus_dev
# LLM provider (openai, xai, openrouter, groq, ollama, deepseek)
# LLM_PROVIDER=xai
# LLM_API_KEY=xai-your-key-here
# LLM_MODEL=grok-3-latest
# LLM_BASE_URL=              # optional override
# LLM_MAX_TOKENS=8192        # optional, default 8192
# LLM_MAX_RETRIES=3          # optional, default 3
OTEL_ENDPOINT=http://localhost:4317
LOG_LEVEL=info

# Port overrides (for multi-instance on same machine)
# ANIMUS_PG_PORT=5432
# ANIMUS_GRAFANA_PORT=3000
# ANIMUS_OTEL_GRPC_PORT=4317
# ANIMUS_OTEL_HTTP_PORT=4318
